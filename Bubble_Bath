<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0, viewport-fit=cover"
  />
  <meta name="theme-color" content="#dff7ff" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <title>Bubble Bath 🫧🛁</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html, body {
      width: 100%;
      min-height: 100dvh;
      overflow: hidden;
      font-family: "Trebuchet MS", "Comic Sans MS", "Arial Rounded MT Bold", sans-serif;
      background:
        radial-gradient(circle at 20% 15%, rgba(255,255,255,0.65) 0%, transparent 18%),
        radial-gradient(circle at 78% 18%, rgba(255, 214, 236, 0.32) 0%, transparent 18%),
        radial-gradient(circle at 70% 75%, rgba(183, 234, 255, 0.30) 0%, transparent 20%),
        linear-gradient(180deg, #e9fbff 0%, #dff5ff 35%, #e9f8ff 65%, #f9efff 100%);
      animation: bgShift 12s ease-in-out infinite alternate;
      cursor: pointer;
    }

    body {
      position: relative;
      padding-top: env(safe-area-inset-top);
      touch-action: none;
    }

    @keyframes bgShift {
      from { filter: brightness(1) saturate(1); }
      to   { filter: brightness(1.03) saturate(1.08); }
    }

    .page-title {
      position: fixed;
      top: calc(env(safe-area-inset-top) + 12px);
      left: 50%;
      transform: translateX(-50%);
      z-index: 30;
      pointer-events: none;
      font-size: clamp(1.8rem, 4vw, 3rem);
      color: #ffffff;
      text-shadow:
        0 0 10px rgba(255,255,255,0.95),
        0 0 18px rgba(184, 236, 255, 0.9),
        0 0 30px rgba(255, 198, 234, 0.75);
      letter-spacing: 2px;
      animation: titleFloat 3.2s ease-in-out infinite;
    }

    @keyframes titleFloat {
      0%, 100% { transform: translateX(-50%) translateY(0) scale(1); }
      50% { transform: translateX(-50%) translateY(-3px) scale(1.03); }
    }

    .foam-top {
      position: absolute;
      top: 70px;
      left: 0;
      width: 100%;
      height: 120px;
      pointer-events: none;
      z-index: 3;
      opacity: 0.9;
      background:
        radial-gradient(circle at 4% 75%, rgba(255,255,255,0.95) 0 28px, transparent 29px),
        radial-gradient(circle at 12% 40%, rgba(255,255,255,0.92) 0 34px, transparent 35px),
        radial-gradient(circle at 20% 70%, rgba(255,255,255,0.97) 0 30px, transparent 31px),
        radial-gradient(circle at 28% 35%, rgba(255,255,255,0.90) 0 38px, transparent 39px),
        radial-gradient(circle at 38% 72%, rgba(255,255,255,0.96) 0 29px, transparent 30px),
        radial-gradient(circle at 48% 42%, rgba(255,255,255,0.95) 0 36px, transparent 37px),
        radial-gradient(circle at 58% 75%, rgba(255,255,255,0.97) 0 28px, transparent 29px),
        radial-gradient(circle at 68% 38%, rgba(255,255,255,0.92) 0 37px, transparent 38px),
        radial-gradient(circle at 78% 68%, rgba(255,255,255,0.97) 0 30px, transparent 31px),
        radial-gradient(circle at 88% 40%, rgba(255,255,255,0.94) 0 35px, transparent 36px),
        radial-gradient(circle at 96% 72%, rgba(255,255,255,0.96) 0 27px, transparent 28px);
      filter: blur(1px);
    }

    .bath {
      position: absolute;
      left: 50%;
      bottom: -2vh;
      transform: translateX(-50%);
      width: min(92vw, 760px);
      height: 38vh;
      min-height: 220px;
      border-radius: 46% 46% 14% 14% / 30% 30% 18% 18%;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.65) 0%, rgba(219,243,255,0.8) 50%, rgba(191,226,255,0.85) 100%);
      border: 3px solid rgba(255,255,255,0.75);
      box-shadow:
        inset 0 14px 30px rgba(255,255,255,0.55),
        0 12px 40px rgba(153, 208, 235, 0.25);
      z-index: 2;
      pointer-events: none;
    }

    .bath::before {
      content: "";
      position: absolute;
      left: 50%;
      top: -18px;
      transform: translateX(-50%);
      width: 96%;
      height: 50px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 10% 70%, rgba(255,255,255,0.98) 0 22px, transparent 23px),
        radial-gradient(circle at 22% 35%, rgba(255,255,255,0.95) 0 28px, transparent 29px),
        radial-gradient(circle at 35% 70%, rgba(255,255,255,0.98) 0 22px, transparent 23px),
        radial-gradient(circle at 48% 35%, rgba(255,255,255,0.95) 0 28px, transparent 29px),
        radial-gradient(circle at 60% 70%, rgba(255,255,255,0.98) 0 22px, transparent 23px),
        radial-gradient(circle at 73% 35%, rgba(255,255,255,0.95) 0 28px, transparent 29px),
        radial-gradient(circle at 88% 68%, rgba(255,255,255,0.98) 0 23px, transparent 24px);
      filter: blur(1px);
    }

    .ducky {
      position: absolute;
      user-select: none;
      pointer-events: none;
      z-index: 8;
      opacity: 0;
      animation-name: floatDucky;
      animation-timing-function: linear;
      animation-iteration-count: infinite;
      filter: drop-shadow(0 5px 10px rgba(255,255,255,0.55));
    }

    @keyframes floatDucky {
      0% {
        transform: translate(var(--x1), var(--y1)) scale(0.8) rotate(-6deg);
        opacity: 0;
      }
      10% { opacity: 1; }
      50% { opacity: 1; }
      100% {
        transform: translate(var(--x2), var(--y2)) scale(1.15) rotate(8deg);
        opacity: 0;
      }
    }

    .bubble {
      position: absolute;
      border-radius: 50%;
      pointer-events: auto;
      z-index: 10;
      opacity: 0;
      background:
        radial-gradient(circle at 30% 30%, rgba(255,255,255,0.95) 0 14%, rgba(255,255,255,0.55) 15%, rgba(190,236,255,0.22) 45%, rgba(255,215,244,0.18) 68%, rgba(255,255,255,0.08) 100%);
      border: 1.5px solid rgba(255,255,255,0.55);
      box-shadow:
        inset -6px -8px 16px rgba(255,255,255,0.22),
        inset 7px 8px 16px rgba(255,255,255,0.40),
        0 0 18px rgba(255,255,255,0.20);
      animation-name: floatBubble;
      animation-timing-function: linear;
      animation-iteration-count: infinite;
    }

    @keyframes floatBubble {
      0% {
        transform: translate(var(--bx1), var(--by1)) scale(0.75);
        opacity: 0;
      }
      8% { opacity: 0.85; }
      50% { opacity: 0.95; }
      100% {
        transform: translate(var(--bx2), var(--by2)) scale(1.2);
        opacity: 0;
      }
    }

    .soap {
      position: absolute;
      user-select: none;
      pointer-events: none;
      z-index: 7;
      opacity: 0;
      animation: driftSoap linear infinite;
      filter: drop-shadow(0 4px 10px rgba(255,255,255,0.5));
    }

    @keyframes driftSoap {
      0% {
        transform: translate(var(--sx1), var(--sy1)) rotate(-10deg) scale(0.8);
        opacity: 0;
      }
      12% { opacity: 0.9; }
      100% {
        transform: translate(var(--sx2), var(--sy2)) rotate(14deg) scale(1.15);
        opacity: 0;
      }
    }

    .sparkle {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.92);
      box-shadow: 0 0 14px rgba(255,255,255,0.95);
      pointer-events: none;
      z-index: 5;
      animation: twinkle 2.4s ease-in-out infinite;
    }

    @keyframes twinkle {
      0%, 100% {
        transform: scale(0.55);
        opacity: 0.22;
      }
      50% {
        transform: scale(1.45);
        opacity: 1;
      }
    }

    .paint {
      position: absolute;
      pointer-events: none;
      user-select: none;
      z-index: 50;
      animation: paintFloat 1.2s ease-out forwards;
      filter: drop-shadow(0 0 10px rgba(255,255,255,0.85));
    }

    @keyframes paintFloat {
      0% {
        transform: translate(0, 0) scale(0.45) rotate(0deg);
        opacity: 0;
      }
      15% {
        opacity: 1;
      }
      100% {
        transform: translate(var(--px), var(--py)) scale(1.2) rotate(var(--pr));
        opacity: 0;
      }
    }

    .pop {
      animation: popBubble 0.28s ease-out forwards !important;
    }

    @keyframes popBubble {
      0% {
        transform: scale(1);
        opacity: 1;
      }
      70% {
        transform: scale(1.22);
        opacity: 0.65;
      }
      100% {
        transform: scale(0.2);
        opacity: 0;
      }
    }

    @media (max-width: 600px) {
      .page-title {
        top: calc(env(safe-area-inset-top) + 10px);
      }
    }
  </style>
</head>
<body>
  <div class="foam-top"></div>
  <div class="bath"></div>

  <div class="page-title">Bubble Bath 🫧🛁</div>

  <script>
    const duckies = ["🦆", "🐥", "🧸", "🧼"];
    const soaps = ["🧼", "🫧", "✨", "🩷"];
    const paintItems = ["🫧", "✨", "💙", "🩷", "🤍", "🧼"];
    const pastelColors = ["#ffffff", "#dff7ff", "#ffd8ef", "#dff3ff", "#f8e8ff", "#cfefff"];

    let isDrawing = false;
    let lastDrawTime = 0;

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function randItem(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function createBubble() {
      const el = document.createElement("div");
      el.className = "bubble";

      const size = rand(28, 90);
      el.style.width = `${size}px`;
      el.style.height = `${size}px`;
      el.style.left = "0";
      el.style.top = "0";
      el.style.setProperty("--bx1", `${rand(-5, 100)}vw`);
      el.style.setProperty("--by1", `${rand(78, 110)}vh`);
      el.style.setProperty("--bx2", `${rand(-8, 100)}vw`);
      el.style.setProperty("--by2", `${rand(-25, 20)}vh`);
      el.style.animationDuration = `${rand(8, 18)}s`;
      el.style.animationDelay = `${rand(0, 8)}s`;

      el.addEventListener("pointerdown", (e) => {
        e.stopPropagation();
        popBubble(el);
      });

      document.body.appendChild(el);
    }

    function popBubble(el) {
      if (!el || el.classList.contains("pop")) return;
      el.classList.add("pop");

      for (let i = 0; i < 6; i++) {
        createMiniPop(
          el.getBoundingClientRect().left + el.offsetWidth / 2,
          el.getBoundingClientRect().top + el.offsetHeight / 2
        );
      }

      setTimeout(() => el.remove(), 260);
      setTimeout(createBubble, rand(400, 1200));
    }

    function createMiniPop(x, y) {
      const mini = document.createElement("div");
      mini.className = "paint";
      mini.textContent = randItem(["✨", "🫧", "💧"]);

      mini.style.left = `${x}px`;
      mini.style.top = `${y}px`;
      mini.style.fontSize = `${rand(10, 18)}px`;
      mini.style.color = randItem(pastelColors);
      mini.style.setProperty("--px", `${rand(-30, 30)}px`);
      mini.style.setProperty("--py", `${rand(-30, 30)}px`);
      mini.style.setProperty("--pr", `${rand(-100, 100)}deg`);
      mini.style.animationDuration = `${rand(0.6, 1.1)}s`;

      document.body.appendChild(mini);
      setTimeout(() => mini.remove(), 1200);
    }

    function createDucky() {
      const el = document.createElement("div");
      el.className = "ducky";
      el.textContent = randItem(duckies);

      el.style.left = "0";
      el.style.top = "0";
      el.style.fontSize = `${rand(24, 52)}px`;
      el.style.setProperty("--x1", `${rand(-10, 100)}vw`);
      el.style.setProperty("--y1", `${rand(45, 92)}vh`);
      el.style.setProperty("--x2", `${rand(-10, 100)}vw`);
      el.style.setProperty("--y2", `${rand(35, 88)}vh`);
      el.style.animationDuration = `${rand(10, 18)}s`;
      el.style.animationDelay = `${rand(0, 10)}s`;

      document.body.appendChild(el);
    }

    function createSoap() {
      const el = document.createElement("div");
      el.className = "soap";
      el.textContent = randItem(soaps);

      el.style.left = "0";
      el.style.top = "0";
      el.style.fontSize = `${rand(18, 34)}px`;
      el.style.setProperty("--sx1", `${rand(-5, 100)}vw`);
      el.style.setProperty("--sy1", `${rand(35, 100)}vh`);
      el.style.setProperty("--sx2", `${rand(-5, 100)}vw`);
      el.style.setProperty("--sy2", `${rand(-20, 20)}vh`);
      el.style.animationDuration = `${rand(8, 16)}s`;
      el.style.animationDelay = `${rand(0, 8)}s`;

      document.body.appendChild(el);
    }

    function createSparkle() {
      const el = document.createElement("div");
      el.className = "sparkle";
      el.style.left = `${rand(0, 100)}vw`;
      el.style.top = `${rand(0, 100)}vh`;
      el.style.animationDelay = `${rand(0, 3)}s`;
      el.style.animationDuration = `${rand(1.8, 3.8)}s`;
      document.body.appendChild(el);
    }

    function createPaint(x, y) {
      const el = document.createElement("div");
      el.className = "paint";
      el.textContent = randItem(paintItems);

      el.style.left = `${x}px`;
      el.style.top = `${y}px`;
      el.style.fontSize = `${rand(14, 28)}px`;
      el.style.color = randItem(pastelColors);
      el.style.setProperty("--px", `${rand(-22, 22)}px`);
      el.style.setProperty("--py", `${rand(-22, 22)}px`);
      el.style.setProperty("--pr", `${rand(-90, 90)}deg`);
      el.style.animationDuration = `${rand(0.7, 1.3)}s`;

      document.body.appendChild(el);
      setTimeout(() => el.remove(), 1300);
    }

    function drawAt(x, y) {
      const now = Date.now();
      if (now - lastDrawTime < 30) return;
      lastDrawTime = now;
      createPaint(x, y);
    }

    document.addEventListener("pointerdown", (e) => {
      isDrawing = true;
      drawAt(e.clientX, e.clientY);
    });

    document.addEventListener("pointermove", (e) => {
      if (!isDrawing) return;
      drawAt(e.clientX, e.clientY);
    });

    document.addEventListener("pointerup", () => {
      isDrawing = false;
    });

    document.addEventListener("pointercancel", () => {
      isDrawing = false;
    });

    document.addEventListener("touchstart", (e) => {
      const touch = e.touches[0];
      if (!touch) return;
      isDrawing = true;
      drawAt(touch.clientX, touch.clientY);
    }, { passive: true });

    document.addEventListener("touchmove", (e) => {
      const touch = e.touches[0];
      if (!touch || !isDrawing) return;
      drawAt(touch.clientX, touch.clientY);
    }, { passive: true });

    document.addEventListener("touchend", () => {
      isDrawing = false;
    });

    for (let i = 0; i < 24; i++) createBubble();
    for (let i = 0; i < 12; i++) createDucky();
    for (let i = 0; i < 18; i++) createSoap();
    for (let i = 0; i < 24; i++) createSparkle();
  </script>
</body>
</html>